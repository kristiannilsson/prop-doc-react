{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": ".",
    "outDir": "dist",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmitOnError": true,
    "declaration": true,
    "sourceMap": false,
    "types": ["node"]
  },
  "include": ["bin/**/*.mts", "lib/**/*.mts"],
  "exclude": ["dist", "test", "testdata", "node_modules"]
}
